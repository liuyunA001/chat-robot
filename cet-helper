def render_chat_area(tab_name, tab_key):
    if tab_name in ["作文润色"]:
        uploaded_file = st.file_uploader(
            "📎 上传作文图片（可选）",
            type=["png", "jpg", "jpeg", "gif"],
            label_visibility="collapsed",
            key=f"upload_{tab_key}"
        )
        if uploaded_file:
            st.image(uploaded_file, width=250)
            st.caption("已上传，可描述问题")

    chat_container = st.container()
    with chat_container:
        if not st.session_state.messages:
            st.markdown("""
            <div class='assistant-message' style='margin-top:20px;'>
                <span class='assistant-avatar'>🧸</span>
                <div style='display:inline-block;'>
                    <p style='margin:0;'>👋 嗨！我是你的备考小助手～<br>选择功能，输入你的问题，我们一起轻松学习吧！</p>
                </div>
            </div>
            """, unsafe_allow_html=True)
            quotes = ["💪 今天也要加油哦！", "🌟 每天进步一点点～", "📚 知识就是力量！"]
            st.markdown(f"""
            <div style='background:#f5edf9; border-radius:30px; padding:0.8rem 1.2rem; margin:1rem 0; text-align:center; color:#6b4d7a;'>
                {random.choice(quotes)}
            </div>
            """, unsafe_allow_html=True)
        else:
            for msg in st.session_state.messages:
                if msg["role"] == "user":
                    st.markdown(f"<div class='user-message'>{msg['content']}</div>", unsafe_allow_html=True)
                else:
                    st.markdown(f"<div class='assistant-message'>{msg['content']}</div>", unsafe_allow_html=True)

    prompt = st.chat_input("输入你的问题...", key=f"chat_{tab_key}")
    if prompt:
        st.session_state.messages.append({"role": "user", "content": prompt})
        st.markdown(f"<div class='user-message'>{prompt}</div>", unsafe_allow_html=True)
        
        sub = None
        if tab_name == "每日背诵":
            sub = st.session_state.current_sub_module
        system_prompt = get_system_prompt(tab_name, sub)
        messages = [{"role": "system", "content": system_prompt}]
        messages.extend(st.session_state.messages)
        
        try:
            response = st.session_state.client.chat.completions.create(
                model="deepseek-chat",
                messages=messages,
                temperature=0.7,
                max_tokens=2000,
                stream=True
            )
            full_response = ""
            placeholder = st.empty()
            for chunk in response:
                if chunk.choices[0].delta.content:
                    content = chunk.choices[0].delta.content
                    full_response += content
                    placeholder.markdown(f"<div class='assistant-message'>{full_response}</div>", unsafe_allow_html=True)
                    time.sleep(0.015)
            st.session_state.messages.append({"role": "assistant", "content": full_response})
        except Exception as e:
            st.error(f"❌ 出错啦：{str(e)}")
            st.stop()

