def get_system_prompt(tab, sub=None):
    if tab == "每日背诵" and sub:
        sub_map = {
            "长难句拆解": "长难句拆解",
            "翻译专项": "翻译专项",
            "阅读解析": "阅读解析",
            "选词填空": "选词填空",
            "段落匹配": "段落匹配"
        }
        key = sub_map.get(sub, "长难句拆解")
    else:
        mapping = {
            "单词打卡": "单词释义",
            "作文润色": "作文批改",
            "口语陪练": "口语对话模拟"
        }
        key = mapping.get(tab, "单词释义")
    return MODULES[key]["system_prompt"]

